{
  "$schema": "node_modules/albatros/schema.json",
  "name": "my-plugin",
  "apx": true,
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "serve": "albatros-cli serve",
    "build": "albatros-cli build"
  },
  "devDependencies": {
    "albatros": "^1.4.2",
    "typescript": "^6.0.3"
  },
  "albatros": {
    "actions": {
      "hello_action": {
        "label": "Приветствие",
        "cmd": "hello",
        "description": "Выводит приветствие в панель сообщений"
      }
    },
    "menu": [
      {
        "label": "Мой плагин",
        "submenu": [
          {
            "action": "hello_action"
          }
        ]
      }
    ]
  }
}
